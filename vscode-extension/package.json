{
  "name": "docmyshi-bridge",
  "displayName": "DocMyShi Bridge",
  "description": "Bridges DocMyShi web app to VS Code Copilot for free AI doc generation",
  "version": "0.4.1",
  "publisher": "xandejpeg",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docmyshi.startBridge",
        "title": "DocMyShi: Start Bridge Server"
      },
      {
        "command": "docmyshi.stopBridge",
        "title": "DocMyShi: Stop Bridge Server"
      }
    ]
  },
  "extensionDependencies": [
    "github.copilot-chat"
  ]
}
